# Скопируйте в .env и подставьте значения: cp .env.example .env

# Настройки основного API-сервиса (вложенная модель, разделитель «.»)
API.BASE_URL=http://localhost:8003
API.TIMEOUT=30

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Подключение к PostgreSQL (одни креды на все сервисные БД, имя БД задаётся в коде)
DATABASE.HOST=localhost
DATABASE.PORT=5432
DATABASE.USER=root
DATABASE.PASSWORD=changeme

# Подключение к Kafka (host-listener PLAINTEXT_HOST, порт 9093 в docker-compose)
KAFKA.BOOTSTRAP_SERVERS=localhost:9093
KAFKA.GROUP_ID=api-auto-tests
KAFKA.AUTO_OFFSET_RESET=earliest
